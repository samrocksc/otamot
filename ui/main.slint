import { VerticalBox, HorizontalBox, Button } from "std-widgets.slint";

export component PomodoroWindow inherits Window {
    width: 200px;
    height: 140px;
    background: #40000000;
    no-frame: true;
    always-on-top: true;
    title: "Pomodoro Timer";

    in-out property <duration> time-left: 1500s;
    in-out property <string> display-text: "25:00";
    in-out property <bool> is-running: false;
    in-out property <bool> is-break: false;

    callback start();
    callback pause();
    callback reset();
    callback toggle-break();
    callback begin_drag(float, float);
    callback continue_drag(float, float);
    callback end_drag();

    property <float> drag-start-x: 0;
    property <float> drag-start-y: 0;
    property <bool> is-dragging: false;

    // Draggable top bar
    Rectangle {
        height: 24px;
        background: #20000000;

        TouchArea {
            mouse-cursor: move;

            clicked => {
                root.is-dragging = true;
                root.drag-start-x = self.pressed-x / 1px;
                root.drag-start-y = self.pressed-y / 1px;
                root.begin_drag(self.pressed-x / 1px, self.pressed-y / 1px);
            }

            moved => {
                if self.pressed && root.is-dragging {
                    let dx = (self.mouse-x - self.pressed-x) / 1px;
                    let dy = (self.mouse-y - self.pressed-y) / 1px;
                    root.continue_drag(dx, dy);
                } else if !self.pressed && root.is-dragging {
                    root.is-dragging = false;
                    root.end_drag();
                }
            }
        }

        // Visual indicator for drag area
        Rectangle {
            x: 90px;
            y: 10px;
            width: 20px;
            height: 4px;
            border-radius: 2px;
            background: #80ffffff;
        }
    }

    VerticalBox {
        y: 24px;
        spacing: 8px;
        padding: 12px;

        Text {
            text: root.display-text;
            font-size: 32px;
            font-weight: 700;
            color: #ffffff;
            horizontal-alignment: center;
        }

        HorizontalBox {
            spacing: 8px;

            Button {
                text: root.is-running ? "Pause" : "Start";
                clicked => {
                    if (!root.is-running) {
                        root.start();
                    } else {
                        root.pause();
                    }
                }
            }

            Button {
                text: "Reset";
                clicked => { root.reset(); }
            }

            Button {
                text: root.is-break ? "Work" : "Break";
                min-width: 50px;
                clicked => { root.toggle-break(); }
            }
        }
    }
}